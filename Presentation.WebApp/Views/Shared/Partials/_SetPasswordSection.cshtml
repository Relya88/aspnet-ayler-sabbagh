@model Presentation.WebApp.Models.SetPasswordViewModel

<section class="set-password-section">
    <div class="set-password-container">

        <div class="set-password-card">
            <h1 class="set-password-title">Set Your Password</h1>

            <p class="set-password-text">
                Set a strong password to protect your account. For security reasons, your password must be at
                least 8 characters long and include uppercase and lowercase letters, numbers, and special
                characters.
            </p>

            <div class="set-password-divider"></div>

            <form method="post" asp-controller="SetPassword" asp-action="Index" class="set-password-form">
                <div class="set-password-field">
                    <label>Email Address</label>
                    <input asp-for="Email" id="setPasswordEmail" type="email" placeholder="username@domain.com" />
                    <span asp-validation-for="Email"></span>
                </div>

                <div class="set-password-field">
                    <label>Password</label>
                    <input asp-for="Password" id="setPasswordValue" type="password" placeholder="Enter Password" />
                    <span asp-validation-for="Password"></span>
                </div>

                <button type="submit" class="set-password-btn">
                    Continue
                    <img src="~/images/Arrow-button.png" asp-append-version="true" alt="" />
                </button>

                <label class="set-password-checkbox-row">
                    <input type="checkbox" />
                    <span>Accept user terms and conditions</span>
                </label>
            </form>
        </div>

    </div>
</section>