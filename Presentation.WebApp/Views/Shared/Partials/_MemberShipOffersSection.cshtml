<section class="membership-offers-section">
    <div class="membership-offers-container">

        <div class="membership-cards">

            <!-- STANDARD -->
            <article class="membership-card">
                <div class="membership-card-icon">
                    <img src="~/images/dumbbell-icon.png" asp-append-version="true" />
                </div>

                <h2 class="membership-card-title">Standard Membership</h2>

                <p class="membership-card-text">
                    With the Standard Membership, get access
                    to our full range of gym facilities.
                </p>

                <ul class="membership-card-list">
                    <li>Standard Locker</li>
                    <li>High-energy group fitness classes</li>
                    <li>Motivating &amp; supportive environment</li>
                </ul>

                <div class="membership-card-bottom">
                    <div class="membership-price-wrap">
                        <div class="membership-price">495.00 <span>/monthly</span></div>

                        <div class="membership-classes">✦ Monthly 20 Classes</div>

                        <a href="#" class="membership-join-btn">
                            Join Now
                            <img src="~/images/Arrow-button.png" asp-append-version="true" alt="" />
                        </a>
                    </div>

                    <div class="membership-card-line"></div>

                    <p class="membership-card-note">
                        Try Any Membership Free for 1 Week
                    </p>
                </div>
            </article>

            <!-- PREMIUM -->
            <article class="membership-card">
                <div class="membership-card-icon">
                    <img src="~/images/dumbbell-icon.png" asp-append-version="true" />
                </div>

                <h2 class="membership-card-title">Premium Membership</h2>

                <p class="membership-card-text">
                    With the Premium Membership, get access
                    to our full range of gym facilities.
                </p>

                <ul class="membership-card-list">
                    <li>Priority Support &amp; Premium Locker</li>
                    <li>High-energy group fitness classes</li>
                    <li>Motivating &amp; supportive environment</li>
                </ul>

                <div class="membership-card-bottom">
                    <div class="membership-price-wrap">

                    <div class="membership-price">
                        495.00 <span>/monthly</span>
                    </div>

                    <div class="membership-classes">
                        ✦ Monthly 20 Classes
                    </div>

                    <a href="#" class="membership-join-btn">
                        Join Now
                        <img src="~/images/Arrow-button.png" asp-append-version="true" />
                    </a>

                </div>

                    <div class="membership-card-line"></div>

                    <p class="membership-card-note">
                        Try Any Membership Free for 1 Week
                    </p>
                </div>
            </article>

            <!-- CTA -->
            <article class="membership-cta-card">
                <h2 class="membership-cta-title">Get Your Membership</h2>

                <p class="membership-cta-text">
                    Our memberships give you access to all
                    equipment, personalized training.
                </p>

                <div class="membership-cta-line"></div>

                <p class="membership-cta-phone">
                    Call Us At: +(46) 8 410 521 00
                </p>

                <a href="#" class="membership-cta-btn">
                    Call Us Today!
                    <img src="~/images/Arrow-button.png" asp-append-version="true" />
                </a>

                <div class="membership-cta-image">
                    <img src="~/images/our-pricing-cta-image.png" asp-append-version="true" />
                </div>
            </article>

        </div>

        <div class="membership-benefits">
            <div class="membership-benefit-item">
                <span class="membership-benefit-icon">◰</span>
                <span>Get 30 day free trial</span>
            </div>

            <div class="membership-benefit-item">
                <span class="membership-benefit-icon">▤</span>
                <span>No any hidden fees pay</span>
            </div>

            <div class="membership-benefit-item">
                <span class="membership-benefit-icon">◔</span>
                <span>You can cancel anytime</span>
            </div>
        </div>

    </div>
</section>