<section class="contact-us-section">
    <div class="contact-us-container">

        <div class="contact-us-image-wrap">
            <img src="~/images/contact-us-image.png" asp-append-version="true" alt="Customer service" />

            <div class="contact-us-info-box">
                <div class="contact-us-info-item">
                    <div class="contact-us-info-icon">⌕</div>
                    <div class="contact-us-info-text">
                        <span class="contact-us-info-label">Phone Number</span>
                        <span class="contact-us-info-value">+(46) 8 410 521 00</span>
                    </div>
                </div>

                <div class="contact-us-info-item">
                    <div class="contact-us-info-icon">✉</div>
                    <div class="contact-us-info-text">
                        <span class="contact-us-info-label">Email Address</span>
                        <span class="contact-us-info-value">info@corefitness.se</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="contact-us-form-wrap">
            <h2 class="contact-us-title">Contact Us Today</h2>

            <p class="contact-us-text">
                Ready to begin your fitness journey? Contact GymPro today and let our
                expert trainers guide you with the right program and support.
            </p>

            <form class="contact-us-form">
                <div class="contact-us-form-row">
                    <div class="contact-us-field">
                        <label for="firstName">First Name *</label>
                        <input id="firstName" type="text" placeholder="Enter First Name" />
                    </div>

                    <div class="contact-us-field">
                        <label for="lastName">Last Name *</label>
                        <input id="lastName" type="text" placeholder="Enter Last Name" />
                    </div>
                </div>

                <div class="contact-us-form-row">
                    <div class="contact-us-field">
                        <label for="email">Email Address *</label>
                        <input id="email" type="email" placeholder="Enter Email Address" />
                    </div>

                    <div class="contact-us-field">
                        <label for="phone">Phone Number</label>
                        <input id="phone" type="text" placeholder="Enter Phone Number" />
                    </div>
                </div>

                <div class="contact-us-field contact-us-field-full">
                    <label for="message">Message *</label>
                    <textarea id="message" placeholder="Message..."></textarea>
                </div>

                <button type="button" class="contact-us-submit-btn">
                    Submit Message
                    <img src="~/images/Arrow-button.png" asp-append-version="true" alt="" />
                </button>
            </form>
        </div>

    </div>
</section>