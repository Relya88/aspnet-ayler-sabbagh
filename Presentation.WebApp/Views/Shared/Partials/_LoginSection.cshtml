<section class="login-section">
    <div class="login-container">

        <div class="login-card">
            <h1 class="login-title">Welcome Back!</h1>

            <p class="login-text">
                Log in to continue your fitness journey with full access to your customized program, training
                history, and progress tracking. Stay consistent, monitor your development, and keep moving
                forward with the structure and support built into your account.
            </p>

            <div class="login-divider"></div>

            <div class="login-socials">
                <a href="#" class="login-social-btn">G</a>
                <a href="#" class="login-social-btn">f</a>
                <a href="#" class="login-social-btn">◉</a>
            </div>

            <div class="login-or-wrap">
                <div class="login-or-line"></div>
                <span class="login-or-text">OR CONTINUE WITH</span>
                <div class="login-or-line"></div>
            </div>

            <form class="login-form">
                <div class="login-field">
                    <label for="loginEmail">Email Address *</label>
                    <input id="loginEmail" type="email" placeholder="Enter Email Address" />
                </div>

                <div class="login-field">
                    <div class="login-label-row">
                        <label for="loginPassword">Password</label>
                        <a href="#" class="login-forgot-link">Forgot your password?</a>
                    </div>
                    <input id="loginPassword" type="password" placeholder="Enter Password" />
                </div>

                <button type="button" class="login-btn">
                    Continue
                    <img src="~/images/Arrow-button.png" asp-append-version="true" alt="" />
                </button>

                <label class="login-checkbox-row">
                    <input type="checkbox" />
                    <span>Accept user terms and conditions</span>
                </label>
            </form>
        </div>

    </div>
</section>