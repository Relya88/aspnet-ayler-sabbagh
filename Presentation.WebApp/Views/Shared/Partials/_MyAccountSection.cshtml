<section class="my-account-section">
    <div class="my-account-container">

        <div class="my-account-grid">

            <div class="my-account-sidebar">

                <div class="my-account-profile-image">
                    <img src="~/images/trainer-1.png" asp-append-version="true" alt="Trainer profile" />
                </div>

                <div class="my-account-menu-card">
                    <div class="my-account-menu-header">Menu Options</div>

                    <a href="#" class="my-account-menu-item active">
                        <span>About Me</span>
                        <span class="my-account-menu-arrow">›</span>
                    </a>

                    <a href="#" class="my-account-menu-item">
                        <span>My Membership</span>
                        <span class="my-account-menu-arrow">›</span>
                    </a>

                    <a href="#" class="my-account-menu-item">
                        <span>My Bookings</span>
                        <span class="my-account-menu-arrow">›</span>
                    </a>

                    <a href="#" class="my-account-menu-item">
                        <span>Sign Out</span>
                        <span class="my-account-menu-arrow">›</span>
                    </a>
                </div>

                <div class="my-account-remove-wrap">
                    <p>If you like to cancel your account click below</p>
                    <a href="#" class="my-account-remove-link">Remove Account</a>
                </div>

            </div>

            <div class="my-account-main">

                <div class="my-account-form-card">
                    <h2 class="my-account-form-title">About Me</h2>

                    <div class="my-account-divider"></div>

                    <form class="my-account-form">
                        <div class="my-account-field">
                            <label for="accountFirstName">First Name</label>
                            <input id="accountFirstName" type="text" placeholder="Enter First Name" />
                        </div>

                        <div class="my-account-field">
                            <label for="accountLastName">Last Name</label>
                            <input id="accountLastName" type="text" placeholder="Enter Last Name" />
                        </div>

                        <div class="my-account-field">
                            <label for="accountEmail">Email Address *</label>
                            <input id="accountEmail" type="email" placeholder="username@domain.com" />
                        </div>

                        <div class="my-account-field">
                            <label for="accountPhone">Phone Number</label>
                            <input id="accountPhone" type="text" placeholder="Enter Phone Number" />
                        </div>

                        <div class="my-account-divider"></div>

                        <div class="my-account-field">
                            <label for="accountProfileImage">Profile Image</label>

                            <div class="my-account-upload-row">
                                <input id="accountProfileImage" type="text" placeholder="Upload Profile Image" />
                                <button type="button" class="my-account-browse-btn">Browse</button>
                            </div>
                        </div>

                        <div class="my-account-actions">
                            <button type="button" class="my-account-save-btn">
                                Save
                                <img src="~/images/Arrow-button.png" asp-append-version="true" alt="" />
                            </button>
                        </div>
                    </form>
                </div>

                <div class="my-account-stats-card">
                    <h2 class="my-account-stats-title">My Statistics</h2>

                    <div class="my-account-stat-item">
                        <div class="my-account-stat-top">
                            <span>Check-In (last 30 days)</span>
                            <span>25</span>
                        </div>
                        <div class="my-account-stat-bar">
                            <div class="my-account-stat-fill fill-1"></div>
                        </div>
                    </div>

                    <div class="my-account-stat-item">
                        <div class="my-account-stat-top">
                            <span>Weight Goal</span>
                            <span>50%</span>
                        </div>
                        <div class="my-account-stat-bar">
                            <div class="my-account-stat-fill fill-2"></div>
                        </div>
                    </div>

                    <div class="my-account-stat-item">
                        <div class="my-account-stat-top">
                            <span>Current BMI</span>
                            <span>27</span>
                        </div>
                        <div class="my-account-stat-bar">
                            <div class="my-account-stat-fill fill-3"></div>
                        </div>
                    </div>
                </div>

            </div>

        </div>

    </div>
</section>